{
  "name": "vs-integrate-tracker",
  "displayName": "Cadence - Coding Activity Tracker",
  "description": "Track real coding activity from VS Code, Cursor, and Antigravity, then visualize sessions, languages, streaks, and productivity in Cadence.",
  "version": "0.2.0",
  "publisher": "vsintegrate",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SATWIKKKKK/ide-grate"
  },
  "bugs": {
    "url": "https://github.com/SATWIKKKKK/ide-grate/issues"
  },
  "homepage": "https://github.com/SATWIKKKKK/ide-grate#readme",
  "keywords": [
    "coding-tracker",
    "time-tracker",
    "productivity",
    "coding-activity",
    "contribution-graph",
    "wakatime",
    "coding-stats",
    "developer-tools"
  ],
  "galleryBanner": {
    "color": "#0a0a0a",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onUri"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vs-integrate.setApiKey",
        "title": "Cadence: Set API Key"
      },
      {
        "command": "vs-integrate.showStatus",
        "title": "Cadence: Show Status"
      },
      {
        "command": "vs-integrate.testConnection",
        "title": "Cadence: Test Connection"
      },
      {
        "command": "vs-integrate.openDashboard",
        "title": "Cadence: Open Dashboard"
      }
    ],
    "configuration": {
      "title": "Cadence",
      "properties": {
        "vsIntegrate.apiKey": {
          "type": "string",
          "default": "",
          "description": "Your Cadence API key (existing vsi_ keys are supported)"
        },
        "vsIntegrate.apiEndpoint": {
          "type": "string",
          "default": "",
          "description": "API endpoint for heartbeat data (e.g. https://vs-integrate.vercel.app/api/heartbeat). Leave blank to use the default endpoint. You can enter either your site URL or the full /api/heartbeat path."
        },
        "vsIntegrate.heartbeatInterval": {
          "type": "number",
          "default": 30,
          "description": "How often to send heartbeats (in seconds)"
        },
        "vsIntegrate.idleTimeout": {
          "type": "number",
          "default": 120,
          "description": "How long before considering user idle (in seconds)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "node-fetch": "^2.7.0"
  }
}
